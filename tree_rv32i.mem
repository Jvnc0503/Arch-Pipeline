08000113 // addi sp, x0, 128   -> Inicializa la pila (Stack Pointer)
00100513 // addi a0, x0, 1     -> Nodo Raíz = 1
00200593 // addi a1, x0, 2     -> Hijo Izquierdo = 2
00300613 // addi a2, x0, 3     -> Hijo Derecho = 3
ffe10113 // addi sp, sp, -4    -> Reserva un espacio en el Stack
00b12023 // sw a1, 0(sp)       -> Guarda la dirección del hijo izquierdo
00c12223 // sw a2, 4(sp)       -> Guarda la dirección del hijo derecho
00250533 // add a0, a0, a1     -> Suma acumulativa de nodos recorridos
00412583 // lw a1, 4(sp)       -> Recupera del Stack para seguir el recorrido
0ca02423 // sw a0, 200(x0)     -> GUARDA LA SUMA TOTAL DE NODOS Y TERMINA